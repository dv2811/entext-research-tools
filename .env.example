# Substack CLI Configuration
# Copy this file to .env and fill in your values

# Session file location (optional)
# If not set, uses platform-specific default:
#   Linux:   ~/.config/substack-reader/session.json
#   macOS:   ~/Library/Application Support/substack-reader/session.json
#   Windows: %APPDATA%\substack-reader\session.json
SUBSTACK_SESSION_FILE=

# Default search settings (optional)
SUBSTACK_SEARCH_MODE=all
SUBSTACK_SEARCH_LANGUAGE=en

# Default inbox settings (optional)
SUBSTACK_INBOX_LIMIT=20

# Build settings (optional)
GOOS=
GOARCH=
